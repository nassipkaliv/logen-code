# Privy Configuration
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret

# JWT Secret (required, generate with: openssl rand -hex 32)
JWT_SECRET=

# Encryption Key for wallet keys (required, generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Admin Password Hash (required, generate with node script below)
ADMIN_PASSWORD_HASH=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/logen

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Server
PORT=3001
DOMAIN=localhost

# Generate Admin Password Hash:
# node -e "const crypto=require('crypto');const salt=crypto.randomBytes(16).toString('hex');const hash=crypto.pbkdf2Sync('YOUR_PASSWORD',salt,10000,64,'sha512').toString('hex');console.log(hash+':'+salt)"
